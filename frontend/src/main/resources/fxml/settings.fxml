<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.shortify.controllers.SettingsController" spacing="40" alignment="TOP_CENTER">
    <padding>
        <Insets top="50" right="20" bottom="50" left="20"/>
    </padding>

    <!-- Header Title -->
    <Label text="Ayarlar" styleClass="title-2"/>

    <!-- Avatar / Icon area to mimic the screenshot -->
    <VBox alignment="CENTER" spacing="10">
        <!-- Use a nice large icon to represent the server/backend -->
        <FontIcon iconLiteral="fth-server" iconSize="64" iconColor="#3b82f6"/> <!-- Accent color -->
        <Label text="Shortify Backend" styleClass="title-4"/>
    </VBox>

    <!-- Settings Group -->
    <VBox spacing="10" maxWidth="550">
        <!-- Section Title (like "Authentication" in screenshot) -->
        <Label text="Bağlantı Yapılandırması" styleClass="text-bold, text-muted">
            <padding><Insets left="10"/></padding>
        </Label>
        
        <!-- Main Card acting as a list of rows -->
        <VBox styleClass="card" spacing="15">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            
            <!-- Row 1: API URL -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <FontIcon iconLiteral="fth-link" iconSize="18" styleClass="text-muted"/>
                <Label text="Sunucu Adresi" prefWidth="120" styleClass="text-bold"/>
                <TextField fx:id="txtApiUrl" promptText="Örn: http://127.0.0.1:8000" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 5 0 5 0;"/>
            </HBox>

            <!-- Divider (simulated with a thin region or just spacing) -->
            <Region style="-fx-background-color: -color-border-default;" prefHeight="1" />
            
            <!-- Row 2: Status -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <FontIcon iconLiteral="fth-activity" iconSize="18" styleClass="text-muted"/>
                <Label text="Durum" prefWidth="120" styleClass="text-bold"/>
                <Label fx:id="lblConnectionStatus" text="Kontrol Ediliyor..." styleClass="badge"/>
                <Region HBox.hgrow="ALWAYS"/>
                
                <Button text="Sına" styleClass="flat" onAction="#testConnection">
                    <graphic>
                        <FontIcon iconLiteral="fth-refresh-cw" iconSize="14"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </VBox>

    <!-- Save Area -->
    <VBox spacing="10" maxWidth="550">
        <Button text="Değişiklikleri Kaydet" maxWidth="Infinity" styleClass="accent" onAction="#saveSettings">
            <padding><Insets top="12" bottom="12"/></padding>
            <graphic>
                <FontIcon iconLiteral="fth-save" iconSize="16" iconColor="white"/>
            </graphic>
        </Button>
        <HBox alignment="CENTER">
            <Label fx:id="lblStatus" text="" visible="false" />
        </HBox>
    </VBox>

</VBox>
